@node Essential Settings
@section Essential Settings

@defopt majutsu-jj-executable
Path to the @samp{jj} binary (default: @samp{"jj"}).
@end defopt

@defopt majutsu-jj-global-arguments
Global arguments passed to all jj commands (default: @samp{("--no-pager" "--color=always")}).
@end defopt

@defopt majutsu-jj-diffstat-columns
Column width used only for @samp{jj diff --stat} (default: @samp{80}). Set to @samp{nil} to inherit terminal width. Raise it if you want more full path visibility; keep it near 80 if you prefer compact stat bars.
@end defopt

@defopt majutsu-transient-default-action
Key used for primary/default action suffixes in Majutsu transients (default: @samp{RET}). Set it to another key description@comma{} such as @samp{.}@comma{} to move the default action key.
@end defopt

@defopt majutsu-show-process-buffer-hint
Whether to append a process-buffer hint to jj errors. The displayed key is resolved from the active bindings@comma{} so Vanilla normally shows @code{$} and Evil normally shows @code{`}.
@end defopt

@defopt majutsu-debug
Enable debug logging for jj operations.
@end defopt

@defopt majutsu-show-command-output
Show jj command output in messages.
@end defopt

@node Confirmation Settings
@section Confirmation Settings

@defopt majutsu-confirm-critical-actions
If non-nil@comma{} prompt for confirmation before critical operations like abandon@comma{} undo@comma{} redo@comma{} rebase.
@end defopt

@defopt majutsu-no-confirm
A list of symbols for actions Majutsu should not confirm@comma{} or @samp{t} to never confirm. Valid symbols: @samp{undo}@comma{} @samp{redo}@comma{} @samp{abandon}@comma{} @samp{bookmark-delete}@comma{} @samp{tag-delete}@comma{} @samp{git-remote-remove}@comma{} @samp{rebase}@comma{} @samp{workspace-forget}@comma{} and @samp{workspace-trash}.
@end defopt

@defopt majutsu-slow-confirm
A list from the same action set that should use @samp{yes-or-no-p} instead of @samp{y-or-n-p}@comma{} or @samp{t} for all of them.
@end defopt

@node Process Options
@section Process Options

@defopt majutsu-process-popup-time
Popup the process buffer if a command takes longer than this many seconds. @samp{-1} means never@comma{} @samp{0} means immediately.
@end defopt

@defopt majutsu-process-log-max
Maximum number of sections to keep in a process log buffer (default: 32).
@end defopt

@defopt majutsu-process-apply-ansi-colors
When non-nil@comma{} convert ANSI escapes in jj output to text properties.
@end defopt

@defopt majutsu-process-timestamp-format
Format string for timestamps in process buffer sections.
